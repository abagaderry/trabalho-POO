         <children>
            <Label fx:id="lblTitulo" alignment="CENTER" prefHeight="15.0" prefWidth="408.0" text="Tela de Relatórios" textAlignment="CENTER">
               <font>
                  <Font name="System Bold Italic" size="30.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <AnchorPane prefHeight="194.0" prefWidth="406.0">
         <children>
            <Button fx:id="btnRelatorio" layoutX="134.0" layoutY="135.0" prefHeight="79.0" prefWidth="136.0" text="Gerar Relatório" />
            <ComboBox fx:id="cmbFiltro" layoutX="127.0" layoutY="80.0" prefWidth="150.0" />
            <ComboBox fx:id="cmbRelatorio" layoutX="127.0" layoutY="21.0" prefWidth="150.0" />
            <Label layoutX="128.0" layoutY="6.0" text="Relatórios" />
