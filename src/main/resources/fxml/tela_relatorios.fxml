<VBox alignment="CENTER" prefHeight="345.0" prefWidth="448.0" spacing="20.0" stylesheets="@../Style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.fatec.controladores.RelatorioController">
   <children>
