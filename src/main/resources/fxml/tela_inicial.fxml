<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="458.0" prefWidth="478.0" spacing="20.0" stylesheets="@../Style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.fatec.controladores.InicialController">

    <children>

        <AnchorPane prefHeight="391.0" prefWidth="438.0">

            <children>
                
                <Button fx:id="btnLogin" layoutX="151.0" layoutY="169.0" onAction="#abrirLogin" prefHeight="89.0" prefWidth="136.0" text="Login" />

                <Button fx:id="btnCadastro" layoutX="151.0" layoutY="287.0" onAction="#abrirCadastro" prefHeight="89.0" prefWidth="136.0" text="Cadastro" />
            <ImageView fitHeight="283.0" fitWidth="478.0" layoutX="7.0" layoutY="-41.0" mouseTransparent="true" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Imagens/Logo.png" />
               </image>
            </ImageView>

            </children>

        </AnchorPane>

    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

</VBox>
