                <Label layoutX="49.0" layoutY="157.0" text="Nome do Cliente" />
                <Label layoutX="541.0" layoutY="157.0" text="Data Nascimento" />
                <Label layoutX="49.0" layoutY="221.0" text="CEP" />
                <Label layoutX="216.0" layoutY="221.0" text="Endereço" />
