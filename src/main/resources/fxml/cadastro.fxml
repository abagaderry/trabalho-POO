<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="773.0" prefWidth="788.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.fatec.controladores.CadastroController">
    <children>
        <AnchorPane prefHeight="95.0" prefWidth="748.0">
            <children>
                <AnchorPane layoutY="-8.0" prefHeight="161.0" prefWidth="752.0">
                    <children>
                        <Button layoutX="289.0" layoutY="56.0" onAction="#Gravar"
                                prefHeight="65.0" prefWidth="87.0" text="Gravar" />
                        <Button layoutX="414.0" layoutY="56.0" onAction="#Excluir"
                                prefHeight="65.0" prefWidth="87.0" text="Excluir" />
                        <Button layoutX="537.0" layoutY="56.0" onAction="#Encerrar"
                                prefHeight="65.0" prefWidth="87.0" text="Encerrar" />
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>

        <AnchorPane prefHeight="544.0" prefWidth="748.0">
            <children>
                <!-- ✅ Trocado id= por fx:id= em todos os campos -->
                <TextField fx:id="txtCPF"     layoutX="49.0"  layoutY="72.0" />
                <TextField fx:id="txtNome"    layoutX="49.0"  layoutY="174.0" prefHeight="26.0" prefWidth="438.0" />
                <TextField fx:id="txtData"    layoutX="542.0" layoutY="174.0" prefHeight="26.0" prefWidth="138.0" />
                <TextField fx:id="txtCEP"     layoutX="49.0"  layoutY="238.0" prefHeight="26.0" prefWidth="127.0" />
                <TextField fx:id="txtNum"     layoutX="542.0" layoutY="238.0" prefHeight="26.0" prefWidth="138.0" />
                <TextField fx:id="txtEnd"     layoutX="211.0" layoutY="238.0" prefHeight="26.0" prefWidth="278.0" />
                <TextField fx:id="txtUF"      layoutX="542.0" layoutY="320.0" prefHeight="26.0" prefWidth="44.0" />
                <TextField fx:id="txtCidade"  layoutX="230.0" layoutY="320.0" prefHeight="26.0" prefWidth="259.0" />
                <TextField fx:id="txtBairro"  layoutX="49.0"  layoutY="320.0" prefHeight="26.0" prefWidth="152.0" />
                <TextField fx:id="txtEmail"   layoutX="221.0" layoutY="388.0" prefHeight="26.0" prefWidth="438.0" />
                <TextField fx:id="txtFone"    layoutX="49.0"  layoutY="388.0" prefHeight="26.0" prefWidth="152.0" />
                <TextField fx:id="txtUsuario" layoutX="49.0"  layoutY="456.0" prefHeight="26.0" prefWidth="152.0" />
                <TextField fx:id="txtSenha"   layoutX="230.0" layoutY="456.0" prefHeight="26.0" prefWidth="311.0" />

                <Label layoutX="49.0"  layoutY="55.0"  text="CPF do cliente" />
                <Label layoutX="49.0"  layoutY="157.0" text="Nome do Cliente" />
                <Label layoutX="541.0" layoutY="157.0" text="Data Nascimento" />
                <Label layoutX="49.0"  layoutY="221.0" text="CEP" />
                <Label layoutX="216.0" layoutY="221.0" text="Endereço" />
                <Label layoutX="541.0" layoutY="221.0" text="Numero/Comp" />
                <Label layoutX="49.0"  layoutY="303.0" text="Bairro" />
                <Label layoutX="235.0" layoutY="303.0" text="Cidade" />
                <Label layoutX="541.0" layoutY="303.0" text="UF" />
                <Label layoutX="49.0"  layoutY="371.0" text="Fone de contato" />
                <Label layoutX="221.0" layoutY="371.0" text="Email" />
                <Label layoutX="49.0"  layoutY="439.0" text="Usuário" />
                <Label layoutX="230.0" layoutY="439.0" text="Senha" />
            </children>
        </AnchorPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>