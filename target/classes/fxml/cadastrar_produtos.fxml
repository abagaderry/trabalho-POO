<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="723.0" prefWidth="446.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.fatec.controladores.CadProdutoController">
   <children>
      <AnchorPane prefHeight="127.0" prefWidth="406.0">
         <children>
            <Button fx:id="btnCadastro" layoutX="220.0" layoutY="25.0" mnemonicParsing="false" onAction="#Cadastro" prefHeight="78.0" prefWidth="134.0" text="Cadastrar Produtos" />
         </children>
      </AnchorPane>
      <AnchorPane prefHeight="482.0" prefWidth="406.0">
         <children>
            <TextField fx:id="txtNome" layoutX="29.0" layoutY="58.0" onAction="#Nome" prefHeight="26.0" prefWidth="206.0" />
            <TextField fx:id="txtDescricao" layoutX="31.0" layoutY="217.0" onAction="#Descricao" prefHeight="148.0" prefWidth="168.0" />
            <TextField fx:id="txtPreco" layoutX="29.0" layoutY="408.0" onAction="#Preco" />
            <ComboBox fx:id="cmbPrescricao" layoutX="30.0" layoutY="133.0" onAction="#Prescricao" prefHeight="26.0" prefWidth="206.0" />
            <Label layoutX="29.0" layoutY="41.0" text="Nome:" />
            <Label layoutX="29.0" layoutY="391.0" text="Preço:" />
            <Label layoutX="29.0" layoutY="200.0" text="Descrição:" />
            <Label layoutX="29.0" layoutY="116.0" text="Precisa de prescrição?" />
         </children>
      </AnchorPane>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
