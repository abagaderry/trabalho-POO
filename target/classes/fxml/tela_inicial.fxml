<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      prefHeight="458.0"
      prefWidth="478.0"
      spacing="20.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.fatec.controladores.InicialController">

    <children>

        <AnchorPane prefHeight="391.0" prefWidth="438.0">

            <children>

                <Label layoutX="170.0"
                       layoutY="30.0"
                       text="Tela Inicial" />

                <Button fx:id="btnLogin"
                        layoutX="152.0"
                        layoutY="99.0"
                        prefHeight="89.0"
                        prefWidth="136.0"
                        text="Login"
                        onAction="#abrirLogin" />

                <Button fx:id="btnCadastro"
                        layoutX="152.0"
                        layoutY="228.0"
                        prefHeight="89.0"
                        prefWidth="136.0"
                        text="Cadastro"
                        onAction="#abrirCadastro" />

            </children>

        </AnchorPane>

    </children>

    <padding>
        <Insets top="20.0"
                right="20.0"
                bottom="20.0"
                left="20.0" />
    </padding>

</VBox>